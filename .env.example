# ReportService local development env example.
#
# DO NOT copy this file to .env and run production with the values as-is.
# The secrets below are deliberate placeholders — RSCSecretValidation refuses to boot Production
# when it sees a "CHANGE_ME" / "GENERATE_WITH" / "PLACEHOLDER" pattern. Run
#   ./scripts/setup.sh
# to generate a .env with real random keys, or replace each CHANGE_ME_* value by hand.
#
# All values bind to the ReportService section via the __ double-underscore convention.

# ---- Deployment environment (READ THIS before any non-local deploy) ----
# docker-compose.yml reads these three as ${VAR:-default} interpolation. With no override (the
# local `HOST_PORT=8082 docker compose up` flow) you get a Development box with the login bypass
# on — convenient on loopback. The SAME compose file backs scripts/stack.sh production|staging and
# scripts/tunnel.sh, so any deployment reachable beyond loopback (especially a Cloudflare tunnel)
# MUST set these to the production-safe values below in its --env-file:
#   - ASPNETCORE_ENVIRONMENT=Production  -> real cookie auth, no developer exception page, HSTS,
#                                           and RSCSecretValidation actually enforces the secrets.
#   - ADMIN_DEV_AUTO_SIGN_IN=false       -> no synthetic 'dev-operator'; operators log in for real.
# (Leaving these unset keeps the dev defaults Development / true — fine ONLY for loopback dev.)
#ASPNETCORE_ENVIRONMENT=Production
#ADMIN_DEV_AUTO_SIGN_IN=false
# Per-IP rate limit (requests/min) the compose stack runs with. The dev default is 600; a real
# deployment should drop this to a sane production value (the standalone ingestion default is 120).
#REPORT_RATE_LIMIT_PER_MINUTE=120

# Shared-secret API key (sent in the apiKey header). This is the permanent ROOT-ADMIN key: it is
# always valid, never expires, and is used to bootstrap managed keys (mint user/admin keys via
# POST /api/v1/keys or the /ApiKeys admin page). Managed keys live in api-keys.db; this one does not.
# Generate with: openssl rand -hex 32
ReportService__ApiKey=CHANGE_ME_RUN_openssl_rand_hex_32_AND_REPLACE_THIS_VALUE

# ---- Managed API keys ----
# SQLite file holding minted keys (admin/user, expiry, revocation, optional per-key limit). Only
# SHA-256 hashes are stored; plaintext is shown once at creation. Resolved under ReportsRoot when
# relative. Its own DB so key auth works regardless of Storage mode.
#ReportService__ApiKeysDbPath=api-keys.db
# Per-minute rate-limit tiers by role. 0 ⇒ fall back to REPORT_RATE_LIMIT_PER_MINUTE. A per-key
# override set at creation time beats these.
#ReportService__ApiKeyAdminRateLimitPerMinute=0
#ReportService__ApiKeyUserRateLimitPerMinute=0

# Filesystem root where uploaded reports are stored (relative paths resolve from the project dir).
ReportService__ReportsRoot=reports

# Maximum allowed upload size in bytes (default 500 MiB).
ReportService__MaxUploadBytes=524288000

# Maximum size of the JSON part alone, in bytes. Checked before the payload is buffered into a
# string, so the per-request memory footprint stays bounded regardless of MaxUploadBytes. Default
# 1 MiB — big enough for any realistic problem-report payload; raise only if your clients send
# huge label arrays.
#ReportService__MaxJsonBytes=1048576

# Allowed platform tags on incoming reports (indexed array override).
ReportService__AllowedPlatforms__0=android
ReportService__AllowedPlatforms__1=ios

# Per-client rate limit, requests per minute.
ReportService__RateLimitPermitsPerMinute=120

# Global concurrency cap on the ingest write path (total in-flight uploads across all clients).
# Shields disk / SQLite from a distributed DoS when many source IPs each sit within the per-IP
# rate limit. Pair with IngestQueueLimit to absorb microbursts without queuing unboundedly.
ReportService__IngestConcurrency=16
ReportService__IngestQueueLimit=16

# Hard wall-clock limit (seconds) on a single ingest operation. Prevents a stuck disk / slow
# upload from holding an IngestConcurrency permit indefinitely.
ReportService__IngestTimeoutSeconds=60

# SqliteCommand timeout (seconds). Caps every query so a slow statement cannot block the permit.
ReportService__SqliteCommandTimeoutSeconds=10

# ---- Auth abuse tracking (persisted, survives restarts) ----
# Sliding-window failure counter + soft ban after repeated failures from the same source IP.
ReportService__AuthAbuseMaxFailures=10
ReportService__AuthAbuseWindowSeconds=60
ReportService__AuthAbuseBanSeconds=300
ReportService__AuthAbuseDbPath=auth-abuse.db

# Storage backend: "FileSystem" (default) or "SqliteIndex" (keeps files on disk and
# additionally maintains a SQLite metadata index that accelerates listing).
ReportService__Storage=FileSystem

# SQLite database path, used only when Storage=SqliteIndex. Admin-supplied and trusted
# (not traversal-validated). Relative paths resolve from the process working directory.
ReportService__SqliteDbPath=reports.db

# ---- Retention ----
# A background sweep in the ingestion process keeps stored reports under a hard size cap and
# deletes anything older than RetentionMaxAgeDays. Set RetentionEnabled=false to skip the timer
# entirely (the admin can still trigger a manual purge from /Maintenance).
#ReportService__RetentionEnabled=true
# Hard cap on total reports footprint, in bytes. Default 10 GiB. After deleting, the sweep aims
# for ~95% of the cap so the next ingest doesn't immediately retrigger.
#ReportService__RetentionMaxBytes=10737418240
# Reports older than this are removed on every sweep, regardless of the size cap. Set to 0 to
# disable age-based deletion.
#ReportService__RetentionMaxAgeDays=30
# How often the background sweep runs (floored at 60s).
#ReportService__RetentionScanIntervalSeconds=3600
#
# Disk-pressure safeguard (opt-in; both default to 0 = off). RetentionMaxBytes above only counts
# report blobs — it does NOT see the analytics/audit SQLite DBs, the backups dir, un-VACUUMed
# slack, or anything else sharing the volume. These two knobs watch the ACTUAL filesystem holding
# ReportsRoot and, when breached, evict oldest reports first (plus a 10% cushion) until free space
# is restored, so unbounded non-report growth can't silently fill the disk and 503 ingestion.
# Set whichever you prefer; if both are set the larger required eviction wins. Recommended:
# leave headroom for the DBs + backups, e.g. keep 2 GiB free OR cap usage at 85%.
#   2 GiB free  = 2147483648    5 GiB free = 5368709120
#ReportService__RetentionMinFreeDiskBytes=0
# Percent (1..99) of the volume that may be in use before the guard evicts. 0 (or out of range)
# disables it. Note: deleting reports only reclaims report blobs — if the pressure is from the
# DBs/backups the sweep logs a warning and you must VACUUM / clean up manually.
#ReportService__RetentionMaxDiskUsagePercent=0

# ---- Admin UI (ReportService.Admin) ----
# Operator sign-in secret. DIFFERENT from the SDK-facing ApiKey above — this is what a human
# types on the /Login form. Generate with: openssl rand -hex 32
Admin__AdminKey=CHANGE_ME_RUN_openssl_rand_hex_32_AND_REPLACE_THIS_VALUE

# Cookie session lifetime in minutes (default 60). The cookie is HttpOnly + SameSite=Strict.
#Admin__SessionMinutes=60

# ---- Analytics identifier hashing ----
# Pepper mixed into the SHA-256 of every anonymousId before it is stored as anonymous_id_hash.
# Without it the hash is a bare SHA-256 of the raw id — trivially rainbow-tabled back to known
# id formats (numeric account ids, order ids), defeating the "never store raw identifiers" goal.
# This is widened by the server-events route, where subjectId is a real account key. Production
# REFUSES TO BOOT the analytics pipeline if this is empty or still a placeholder (enforced by
# RSCSecretValidation). Generate with: openssl rand -hex 32
# Friendly alias: ANALYTICS_HASH_PEPPER=...  (mapped to Analytics:IdentifierHashPepper)
Analytics__IdentifierHashPepper=CHANGE_ME_RUN_openssl_rand_hex_32_AND_REPLACE_THIS_VALUE

# ---- Public access via Cloudflare Tunnel (optional, opt-in) ----
# Activated by running the stack with `--profile tunnel`, e.g.:
#   docker compose --env-file .env --profile tunnel up -d
#   ./scripts/tunnel.sh up
#
# SECURITY — the tunnel publishes the admin UI to the public internet. Before bringing it up you
# MUST set ASPNETCORE_ENVIRONMENT=Production and ADMIN_DEV_AUTO_SIGN_IN=false (see the top of this
# file) so real cookie auth gates the admin pages and the PII NDJSON exports. The app also gates
# the DevAutoSignIn bypass to loopback only, but do not rely on that alone — run the tunnel as a
# real Production deployment.
#
# RATE LIMITING / ABUSE BANNING behind the tunnel — cloudflared reaches the app over the compose
# network, so EVERY public client arrives at Kestrel with the SAME source IP (the tunnel
# container's). The per-IP rate limiter and the auth-abuse ban then share one bucket for the whole
# internet: one abuser can soft-ban every real client, or the budget is effectively unbounded
# per real client. To keep these controls per-real-client, enable ProxyHeaders (below) with the
# compose network in KnownNetworks AND have cloudflared forward X-Forwarded-For. Until you do, the
# per-IP controls are NOT meaningful behind the tunnel.
#
# The default command opens a fresh *.trycloudflare.com URL every restart — no Cloudflare account
# required. To bind a stable hostname on your own domain instead, create a named tunnel:
#   cloudflared tunnel login                  # one-time browser auth
#   cloudflared tunnel create report-service  # records credentials JSON
#   cloudflared tunnel route dns report-service reports.example.com
#   cloudflared tunnel token  report-service  # prints the token, paste below
# Then uncomment:
#CLOUDFLARED_COMMAND=tunnel --no-autoupdate run --token REPLACE_WITH_TUNNEL_TOKEN

# ---- Proxy / forwarded headers (disabled by default) ----
# Only enable this when the service sits behind a reverse proxy whose network you can enumerate.
# Enabling without KnownProxies / KnownNetworks entries will trust X-Forwarded-For from any direct
# client, letting callers spoof their source IP past rate limits + auth-abuse tracking.
#ProxyHeaders__Enabled=true
#ProxyHeaders__KnownProxies__0=10.0.0.5
#ProxyHeaders__KnownNetworks__0=10.0.0.0/8
#ProxyHeaders__ForwardLimit=1
