# ReportService local development env example.
#
# DO NOT copy this file to .env and run production with the values as-is.
# The secrets below are deliberate placeholders — RSCSecretValidation refuses to boot Production
# when it sees a "CHANGE_ME" / "GENERATE_WITH" / "PLACEHOLDER" pattern. Run
#   ./scripts/setup.sh
# to generate a .env with real random keys, or replace each CHANGE_ME_* value by hand.
#
# All values bind to the ReportService section via the __ double-underscore convention.

# Shared-secret API key required on every request (sent in the apiKey header).
# Generate with: openssl rand -hex 32
ReportService__ApiKey=CHANGE_ME_RUN_openssl_rand_hex_32_AND_REPLACE_THIS_VALUE

# Filesystem root where uploaded reports are stored (relative paths resolve from the project dir).
ReportService__ReportsRoot=reports

# Maximum allowed upload size in bytes (default 500 MiB).
ReportService__MaxUploadBytes=524288000

# Maximum size of the JSON part alone, in bytes. Checked before the payload is buffered into a
# string, so the per-request memory footprint stays bounded regardless of MaxUploadBytes. Default
# 1 MiB — big enough for any realistic problem-report payload; raise only if your clients send
# huge label arrays.
#ReportService__MaxJsonBytes=1048576

# Allowed platform tags on incoming reports (indexed array override).
ReportService__AllowedPlatforms__0=android
ReportService__AllowedPlatforms__1=ios

# Per-client rate limit, requests per minute.
ReportService__RateLimitPermitsPerMinute=120

# Global concurrency cap on the ingest write path (total in-flight uploads across all clients).
# Shields disk / SQLite from a distributed DoS when many source IPs each sit within the per-IP
# rate limit. Pair with IngestQueueLimit to absorb microbursts without queuing unboundedly.
ReportService__IngestConcurrency=16
ReportService__IngestQueueLimit=16

# Hard wall-clock limit (seconds) on a single ingest operation. Prevents a stuck disk / slow
# upload from holding an IngestConcurrency permit indefinitely.
ReportService__IngestTimeoutSeconds=60

# SqliteCommand timeout (seconds). Caps every query so a slow statement cannot block the permit.
ReportService__SqliteCommandTimeoutSeconds=10

# ---- Auth abuse tracking (persisted, survives restarts) ----
# Sliding-window failure counter + soft ban after repeated failures from the same source IP.
ReportService__AuthAbuseMaxFailures=10
ReportService__AuthAbuseWindowSeconds=60
ReportService__AuthAbuseBanSeconds=300
ReportService__AuthAbuseDbPath=auth-abuse.db

# Storage backend: "FileSystem" (default) or "SqliteIndex" (keeps files on disk and
# additionally maintains a SQLite metadata index that accelerates listing).
ReportService__Storage=FileSystem

# SQLite database path, used only when Storage=SqliteIndex. Admin-supplied and trusted
# (not traversal-validated). Relative paths resolve from the process working directory.
ReportService__SqliteDbPath=reports.db

# ---- Retention ----
# A background sweep in the ingestion process keeps stored reports under a hard size cap and
# deletes anything older than RetentionMaxAgeDays. Set RetentionEnabled=false to skip the timer
# entirely (the admin can still trigger a manual purge from /Maintenance).
#ReportService__RetentionEnabled=true
# Hard cap on total reports footprint, in bytes. Default 10 GiB. After deleting, the sweep aims
# for ~95% of the cap so the next ingest doesn't immediately retrigger.
#ReportService__RetentionMaxBytes=10737418240
# Reports older than this are removed on every sweep, regardless of the size cap. Set to 0 to
# disable age-based deletion.
#ReportService__RetentionMaxAgeDays=30
# How often the background sweep runs (floored at 60s).
#ReportService__RetentionScanIntervalSeconds=3600

# ---- Admin UI (ReportService.Admin) ----
# Operator sign-in secret. DIFFERENT from the SDK-facing ApiKey above — this is what a human
# types on the /Login form. Generate with: openssl rand -hex 32
Admin__AdminKey=CHANGE_ME_RUN_openssl_rand_hex_32_AND_REPLACE_THIS_VALUE

# Cookie session lifetime in minutes (default 60). The cookie is HttpOnly + SameSite=Strict.
#Admin__SessionMinutes=60

# ---- Proxy / forwarded headers (disabled by default) ----
# Only enable this when the service sits behind a reverse proxy whose network you can enumerate.
# Enabling without KnownProxies / KnownNetworks entries will trust X-Forwarded-For from any direct
# client, letting callers spoof their source IP past rate limits + auth-abuse tracking.
#ProxyHeaders__Enabled=true
#ProxyHeaders__KnownProxies__0=10.0.0.5
#ProxyHeaders__KnownNetworks__0=10.0.0.0/8
#ProxyHeaders__ForwardLimit=1
