# Build artifacts
**/bin/
**/obj/

# IDE / editor
**/.vs/
**/*.user
**/*.suo

# Local secrets / env
.env
.env.*

# Tooling that is not part of the runtime image (other agents own these)
scripts/
ops/
tests/
ReportService.sln

# appsettings.Development.json IS shipped: the docker-compose dev stack runs with
# ASPNETCORE_ENVIRONMENT=Development and relies on it for worker cadences, retention, and
# logging. It is inert under Production/Staging (those environments never load it), so it
# carries no cost in the prod/staging images built from the same Dockerfile.

# Misc junk
**/.DS_Store

# Repo meta (not needed inside the image)
# README.md is now needed: the admin project bundles it into /app/admin/admin-docs/
# for the /Docs preview page (see src/ReportService.Admin/ReportService.Admin.csproj).
.gitignore
docker-compose.yml
Dockerfile
.dockerignore
