    {
      "name": "Analytics v2 — Ingestion",
      "description": "POST batches to the v2 analytics pipeline at /api/v2/analytics/events.\n\nRequires: apiKey header. All events are validated server-side; rejected events land in the dead-letter queue visible on /AnalyticsHealth.",
      "item": [
        {
          "name": "Submit valid batch (3 events)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('202 Accepted',     () => pm.response.to.have.status(202));",
                  "const j = pm.response.json();",
                  "pm.test('batchId returned',  () => pm.expect(j.batchId).to.be.a('string').and.not.be.empty);",
                  "pm.test('not batch-rejected', () => pm.expect(j.batchRejected).to.be.false);",
                  "pm.test('no events rejected', () => pm.expect(j.rejectedCount).to.equal(0));",
                  "// accepted + duplicate = 3 on both first run and idempotent re-run",
                  "pm.test('all 3 events accounted for', () => pm.expect(j.acceptedCount + j.duplicateCount).to.equal(3));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schemaVersion\": 1,\n  \"batchId\": \"postman-batch-valid-001\",\n  \"platform\": \"android\",\n  \"sdkVersion\": \"2.0.0\",\n  \"hostAppVersion\": \"4.5.0\",\n  \"anonymousId\": \"postman-anon-001\",\n  \"clientId\": null,\n  \"generatedAt\": \"{{$isoTimestamp}}\",\n  \"events\": [\n    {\n      \"eventId\": \"postman-evt-001\",\n      \"sessionId\": \"postman-session-001\",\n      \"sequence\": 1,\n      \"occurredAt\": \"{{$isoTimestamp}}\",\n      \"type\": \"lifecycle\",\n      \"name\": \"session_start\",\n      \"properties\": { \"cold_start\": \"false\", \"host_app_state\": \"foreground\" }\n    },\n    {\n      \"eventId\": \"postman-evt-002\",\n      \"sessionId\": \"postman-session-001\",\n      \"sequence\": 2,\n      \"occurredAt\": \"{{$isoTimestamp}}\",\n      \"type\": \"screen\",\n      \"name\": \"screen_view\",\n      \"screen\": \"home\",\n      \"properties\": { \"device_model\": \"Postman\", \"os_version\": \"test\" }\n    },\n    {\n      \"eventId\": \"postman-evt-003\",\n      \"sessionId\": \"postman-session-001\",\n      \"sequence\": 3,\n      \"occurredAt\": \"{{$isoTimestamp}}\",\n      \"type\": \"error\",\n      \"name\": \"sdk_batch_http_error\",\n      \"feature\": \"sdk\",\n      \"properties\": { \"status_code\": \"503\", \"events_count\": \"12\", \"retryable\": \"true\" }\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v2/analytics/events",
              "host": ["{{baseUrl}}"],
              "path": ["api","v2","analytics","events"]
            }
          }
        },
        {
          "name": "Submit batch — schema version rejected",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('202 Accepted',      () => pm.response.to.have.status(202));",
                  "const j = pm.response.json();",
                  "pm.test('batch rejected',     () => pm.expect(j.batchRejected).to.be.true);",
                  "pm.test('schema version reason', () => pm.expect(j.batchRejectReason).to.include('schema_version'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schemaVersion\": 99,\n  \"batchId\": \"postman-batch-bad-schema-001\",\n  \"platform\": \"android\",\n  \"sdkVersion\": \"2.0.0\",\n  \"hostAppVersion\": \"4.5.0\",\n  \"anonymousId\": \"postman-anon-001\",\n  \"generatedAt\": \"{{$isoTimestamp}}\",\n  \"events\": [\n    {\n      \"eventId\": \"postman-evt-bad-001\",\n      \"sessionId\": \"postman-session-bad\",\n      \"sequence\": 1,\n      \"occurredAt\": \"{{$isoTimestamp}}\",\n      \"type\": \"screen\",\n      \"name\": \"screen_view\",\n      \"properties\": {}\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v2/analytics/events",
              "host": ["{{baseUrl}}"],
              "path": ["api","v2","analytics","events"]
            }
          }
        },
        {
          "name": "Submit batch — PII key rejected",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('202 Accepted',         () => pm.response.to.have.status(202));",
                  "const j = pm.response.json();",
                  "pm.test('batch not rejected',    () => pm.expect(j.batchRejected).to.be.false);",
                  "pm.test('one event rejected',    () => pm.expect(j.rejectedCount).to.equal(1));",
                  "pm.test('zero accepted',         () => pm.expect(j.acceptedCount).to.equal(0));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schemaVersion\": 1,\n  \"batchId\": \"postman-batch-pii-001\",\n  \"platform\": \"android\",\n  \"sdkVersion\": \"2.0.0\",\n  \"hostAppVersion\": \"4.5.0\",\n  \"anonymousId\": \"postman-anon-002\",\n  \"generatedAt\": \"{{$isoTimestamp}}\",\n  \"events\": [\n    {\n      \"eventId\": \"postman-evt-pii-001\",\n      \"sessionId\": \"postman-session-pii\",\n      \"sequence\": 1,\n      \"occurredAt\": \"{{$isoTimestamp}}\",\n      \"type\": \"action\",\n      \"name\": \"user_action\",\n      \"properties\": { \"email\": \"user@example.com\" }\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v2/analytics/events",
              "host": ["{{baseUrl}}"],
              "path": ["api","v2","analytics","events"]
            }
          }
        },
        {
          "name": "Submit SDK error events (sdk_batch_http_error + sdk_api_http_error)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('202 Accepted',       () => pm.response.to.have.status(202));",
