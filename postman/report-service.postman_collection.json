    {
      "name": "Ingestion — JSON crash reports",
      "description": "JSON ingestion endpoint (kind=crash). One POST per crash; the body is the canonical `RSCProblemReport` envelope.",
      "item": [
        {
          "name": "Android JVM crash · /api/v1/reports",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.test('persisted file name returned', () => pm.expect(j.fileName).to.match(/^problem-report_/));",
                  "pm.collectionVariables.set('lastFileName', j.fileName);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"platform\": \"android\",\n  \"kind\": \"crash\",\n  \"title\": \"java.lang.RuntimeException\",\n  \"message\": \"Automatic crash report\\nThread: main\\nReason: UNCAUGHT_EXCEPTION\\nSDK related: false\\nMessage: Postman fixture crash\",\n  \"deviceModel\": \"{{deviceModel}}\",\n  \"appVersion\": \"{{appVersion}}\",\n  \"source\": \"SDK\",\n  \"pharmacyId\": \"{{pharmacyId}}\",\n  \"userId\": \"{{installUserId}}\",\n  \"labels\": [\"SDKV2\", \"fixture\", \"postman\"],\n  \"stackTrace\": \"java.lang.RuntimeException: Postman fixture crash\\n\\tat de.example.fixture.PostmanCrasherKt.crashNow(PostmanCrasherKt.kt:42)\\n\\tat de.example.fixture.MainActivity.onCreate(MainActivity.kt:17)\\n\\tat android.app.Activity.performCreate(Activity.java:8595)\",\n  \"occurredAt\": \"2026-05-12T10:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/reports",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","reports"]
            }
          }
        },
        {
          "name": "iOS demo crash · /api/v1/reports",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"platform\": \"ios\",\n  \"kind\": \"crash\",\n  \"title\": \"DemoTriggeredCrash.postman_fixture: Postman fixture crash\",\n  \"message\": \"Postman iOS fixture\",\n  \"deviceModel\": \"iPhone\",\n  \"appVersion\": \"0.0.1\",\n  \"source\": \"demo-app\",\n  \"labels\": [\"SDKV2\", \"crash\", \"fixture\"],\n  \"userId\": \"{{installUserId}}\",\n  \"stackTrace\": \"DemoTriggeredCrash.postman_fixture: Postman fixture crash\\n0   IASDK                postmanFixtureCrash()\\n1   DemoCrashHook        emit(trigger:message:)\",\n  \"occurredAt\": \"2026-05-12T10:01:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/reports",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","reports"]
            }
          }
        }
      ]
    },
