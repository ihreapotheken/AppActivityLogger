          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schemaVersion\": 1,\n  \"batchId\": \"postman-batch-sdk-errors-001\",\n  \"platform\": \"ios\",\n  \"sdkVersion\": \"2.0.0-ios\",\n  \"hostAppVersion\": \"4.5.0-ios\",\n  \"anonymousId\": \"postman-anon-ios-001\",\n  \"clientId\": null,\n  \"generatedAt\": \"{{$isoTimestamp}}\",\n  \"events\": [\n    {\n      \"eventId\": \"postman-sdk-err-001\",\n      \"sessionId\": \"sdk-diag-postman-test\",\n      \"sequence\": 1,\n      \"occurredAt\": \"{{$isoTimestamp}}\",\n      \"type\": \"error\",\n      \"name\": \"sdk_batch_http_error\",\n      \"feature\": \"sdk\",\n      \"properties\": { \"status_code\": \"429\", \"events_count\": \"20\", \"retryable\": \"true\" }\n    },\n    {\n      \"eventId\": \"postman-sdk-err-002\",\n      \"sessionId\": \"sdk-diag-postman-test\",\n      \"sequence\": 2,\n      \"occurredAt\": \"{{$isoTimestamp}}\",\n      \"type\": \"error\",\n      \"name\": \"sdk_api_http_error\",\n      \"feature\": \"sdk\",\n      \"properties\": { \"status_code\": \"401\", \"error_class\": \"HttpError\" }\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v2/analytics/events",
              "host": ["{{baseUrl}}"],
              "path": ["api","v2","analytics","events"]
            }
          }
        }
      ]
    },
    {
      "name": "Analytics v2 — Admin exports",
      "description": "NDJSON streaming exports for offline analysis. Requires the admin session cookie — run **Admin — sign in / Prime DevAutoSignIn cookie** first.\n\nEach line of the response is a standalone JSON object; pipe through `jq` or import as a newline-delimited JSON file. Capped at 50,000 rows per request.",
      "item": [
        {
          "name": "Events NDJSON — all (first 500)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('NDJSON content type', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('ndjson'));",
                  "const lines = pm.response.text().split('\\n').filter(l => l.trim());",
                  "pm.test('at least one line', () => pm.expect(lines.length).to.be.above(0));",
                  "pm.test('first line is valid JSON with eventId', () => {",
                  "    const obj = JSON.parse(lines[0]);",
                  "    pm.expect(obj).to.have.property('eventId');",
                  "    pm.expect(obj).to.have.property('type');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/api/analytics/events.ndjson?limit=500",
              "host": ["{{baseUrl}}"],
              "path": ["admin","api","analytics","events.ndjson"],
              "query": [{ "key": "limit", "value": "500" }]
            }
          }
