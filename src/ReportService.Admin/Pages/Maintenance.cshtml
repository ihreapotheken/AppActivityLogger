@page
@model RSAMaintenanceModel
@using ReportService.Admin.ViewModels
@using ReportService.Storage.ApiKeys
@{
    ViewData["Title"] = "Maintenance";
}
@await Html.PartialAsync("_PageHeader", new RSAPageHeaderVM("Maintenance", "Operator-triggered actions: retention sweep, index rebuild, integrity, vacuum, backup, export."))

@if (!Model.IndexAvailable)
{
    <div class="error">
        The SQLite metadata index isn't available in this deployment (either <code>Storage != "SqliteIndex"</code>
        or the DB is currently unreachable). Rebuild / integrity / vacuum / backup are disabled until it's back.
    </div>
}

@if (!string.IsNullOrEmpty(Model.NewKeyPlaintext))
{
    <section class="card danger-zone">
        <h2>New key @Model.NewKeyId — copy it now</h2>
        <p class="muted">This is the only time the secret is shown. Store it securely; the server keeps only a hash and can never display it again.</p>
        <pre class="mono">@Model.NewKeyPlaintext</pre>
    </section>
}

<section class="card">
    <h2>API keys</h2>
    <p class="muted">
        Mint and revoke API keys for the ingestion API. Admin keys can manage keys + ingest; user
        keys can only ingest. The static configured key is the permanent root-admin and isn't listed here.
    </p>
    <form method="post" asp-page-handler="CreateApiKey">
        @Html.AntiForgeryToken()
        <div class="kv">
            <label>Role
                <select name="role">
                    <option value="user" selected>user (ingest only)</option>
                    <option value="admin">admin (manage keys + ingest)</option>
                </select>
            </label>
            <label>Label <input type="text" name="label" placeholder="e.g. partner-acme-prod" maxlength="200" /></label>
            <label>Expires in (days) <input type="number" name="expiresInDays" min="1" placeholder="blank = never" /></label>
            <label>Rate limit / min <input type="number" name="rateLimitPerMinute" min="1" placeholder="blank = role default" /></label>
        </div>
        <button type="submit" class="primary">Create key</button>
    </form>

    <h3>Keys (@Model.ApiKeys.Count)</h3>
    @if (Model.ApiKeys.Count == 0)
    {
        <p class="muted">No managed keys yet. The static configured key (root-admin) still works and is not listed here.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>ID</th><th>Role</th><th>Label</th><th>Created</th><th>Expires</th><th>Rate/min</th><th>Status</th><th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var k in Model.ApiKeys)
                {
                    <tr>
                        <td class="mono">@k.Id</td>
                        <td class="mono">@k.Role</td>
                        <td>@(string.IsNullOrEmpty(k.Label) ? "—" : k.Label)</td>
                        <td class="mono" data-sort-value="@k.CreatedAt.UtcDateTime.ToString("o")">@k.CreatedAt.AsLocalTime()</td>
                        <td class="mono">@(k.ExpiresAt is { } e ? e.AsLocalTime() : "never")</td>
                        <td class="mono">@(k.RateLimitPerMinute?.ToString() ?? "default")</td>
                        <td>
                            @if (k.IsRevoked)
                            {
                                <span class="badge badge-bad">revoked</span>
                            }
                            else if (k.IsExpired(Model.Now))
                            {
                                <span class="badge badge-bad">expired</span>
                            }
                            else
                            {
                                <span class="badge badge-ok">active</span>
                            }
                        </td>
                        <td>
                            @if (!k.IsRevoked)
                            {
                                <form method="post" asp-page-handler="RevokeApiKey"
                                      data-confirm="Revoke key @k.Id? Any client using it will get 401 immediately."
                                      data-confirm-title="Revoke API key" data-confirm-label="Revoke">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@k.Id" />
                                    <button type="submit" class="danger">Revoke</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

<section class="card">
    <h2>Retention</h2>
    <p class="muted">
        Storage is capped at <strong>@RSAByteFormatter.Format(Model.Retention.LimitBytes)</strong>; reports older than
        <strong>@Model.Retention.MaxAgeDays days</strong> are also removed. Currently using
        <strong>@RSAByteFormatter.Format(Model.Retention.UsedBytes)</strong> across @Model.Retention.ReportCount reports
        @if (Model.Retention.Oldest is { } oldest)
        {
            <span>(oldest @oldest.AsLocalTime()).</span>
        }
        else
        {
            <span>.</span>
        }
        @if (!Model.Retention.Enabled)
        {
            <span class="badge">Background sweep disabled</span>
        }
    </p>
    <form method="post" asp-page-handler="Purge">
        @Html.AntiForgeryToken()
        <button type="submit" class="primary">Run retention sweep</button>
    </form>
    <p class="muted small">Only deletes reports older than the retention window or oldest-first if over the size cap. To delete <em>everything</em>, use Wipe all data below.</p>
</section>

<section class="card">
    <h2>Index rebuild</h2>
    <p class="muted">Reconcile the SQLite metadata index with the files on disk. Adds rows for files that aren't indexed; removes rows whose files are gone.</p>
    <form method="post" asp-page-handler="Rebuild">
        @Html.AntiForgeryToken()
        <button type="submit" class="primary" @(Model.IndexAvailable ? "" : "disabled")>Rebuild now</button>
    </form>
</section>

<section class="card">
    <h2>Integrity check</h2>
    <p class="muted">Runs <code>PRAGMA integrity_check</code> against the live index DB. The result appears on the Status page.</p>
    <form method="post" asp-page-handler="Integrity">
        @Html.AntiForgeryToken()
        <button type="submit" @(Model.IndexAvailable ? "" : "disabled")>Run integrity check</button>
    </form>
</section>

<section class="card">
    <h2>Vacuum / analyze</h2>
    <p class="muted">Rebuilds the DB to reclaim free pages, then runs <code>ANALYZE</code> to refresh planner stats. Safe to run online, but holds a write lock briefly.</p>
    <form method="post" asp-page-handler="Vacuum">
        @Html.AntiForgeryToken()
        <button type="submit" @(Model.IndexAvailable ? "" : "disabled")>VACUUM + ANALYZE</button>
    </form>
</section>

<section class="card">
    <h2>Backup snapshot</h2>
    <p class="muted">Writes a consistent <code>VACUUM INTO</code> snapshot to <code>@Model.BackupRoot</code>. The snapshot is verified before being published atomically — a crash mid-copy leaves a <code>*.partial.*</code> file for cleanup, never a corrupt backup.</p>
    <form method="post" asp-page-handler="Backup">
        @Html.AntiForgeryToken()
        <button type="submit" class="primary" @(Model.IndexAvailable ? "" : "disabled")>Create backup now</button>
    </form>
    @if (Model.ExistingBackups.Count > 0)
    {
        <h3>Recent backups</h3>
        <table>
            <thead>
                <tr>
                    <th scope="col" tip="Backup snapshot file name (*.db)" sort="text">File</th>
                    <th scope="col" tip="On-disk size of the backup snapshot" sort="num">Size</th>
                    <th scope="col" tip="When the snapshot file was last written (local time)" sort="date">Modified</th>
                    <th scope="col"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in Model.ExistingBackups)
                {
                    <tr>
                        <td class="mono">@f.Name</td>
                        <td data-sort-value="@f.Length">@RSAByteFormatter.Format(f.Length)</td>
                        <td class="mono" data-sort-value="@f.LastWriteTimeUtc.ToString("o")">@f.LastWriteTimeUtc.AsLocalTime()</td>
                        <td><a asp-page-handler="DownloadBackup" asp-route-name="@f.Name">download</a></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

<section class="card">
    <h2>Export metadata</h2>
    <p class="muted">Exports platform / filename / size / submitted-at / attachment columns for every stored report. CSV by default.</p>
    <form method="post" asp-page-handler="Export" class="form-row">
        @Html.AntiForgeryToken()
        <label>Format
            <select name="format">
                <option value="csv">CSV</option>
                <option value="json">JSON</option>
            </select>
        </label>
        <button type="submit" class="primary">Download</button>
    </form>
</section>

<section class="card">
    <h2>Restore</h2>
    <p class="muted">
        Replace the live SQLite index with a previously-taken snapshot. The uploaded file is validated
        (SQLite header + <code>PRAGMA integrity_check</code>) before it touches the live database;
        any failure leaves the live DB untouched. After restore, run an Integrity check + index Rebuild
        to reconcile reports added since the snapshot.
    </p>
    <form method="post" asp-page-handler="Restore" enctype="multipart/form-data" class="form-row" data-confirm-restore>
        @Html.AntiForgeryToken()
        <label>Snapshot file
            <input type="file" name="file" accept=".db,application/x-sqlite3,application/octet-stream" required />
        </label>
        <button type="submit" class="danger">Restore</button>
    </form>
    <p class="muted">Maximum upload size 200 MiB.</p>
</section>

<section class="card">
    <h2>Rotate identifier-hash pepper</h2>
    <p class="muted">
        After updating <code>Analytics:IdentifierHashPepper</code> and bumping
        <code>Analytics:IdentifierHashVersion</code> in configuration <em>and</em> restarting the
        service, run this to purge stale user-day rollups under previous hash versions. Cohorts will
        start fresh under the current version (currently <code>@Model.AnalyticsHashVersion</code>).
        <strong>This is destructive to retention cohort continuity — there is no way to merge old
        and new hashes since raw IDs are not stored.</strong>
    </p>
    <form method="post" asp-page-handler="RotatePepper" class="filter-form">
        @Html.AntiForgeryToken()
        <label>
            <span>Type <code>ROTATE</code> to confirm</span>
            <input name="confirm" required pattern="ROTATE" placeholder="ROTATE" autocomplete="off" />
        </label>
        <button type="submit" class="danger">Purge old user-day rows</button>
    </form>
</section>

<section class="card">
    <h2>Import legacy analytics</h2>
    <p class="muted">
        One-shot migration that scans persisted problem reports for <code>kind = "analytics"</code>
        entries and folds them into the v2 analytics pipeline. Idempotent on (platform, eventId) —
        re-running is safe. Once the SDKs are emitting <code>/api/v2/analytics/events</code> directly
        and the existing legacy data has been imported, this action can be ignored.
    </p>
    <form method="post" asp-page-handler="ImportAnalytics">
        @Html.AntiForgeryToken()
        <button type="submit">Import now</button>
    </form>
</section>

<section class="card danger-zone">
    <h2>Wipe all data</h2>
    <p class="muted">
        Deletes every stored problem report (JSON + gzip attachment) on every platform plus every
        row in the forced-report allow-list. The audit log is intentionally preserved so this
        action stays traceable. <strong>Irreversible — there is no undo.</strong>
    </p>
    <form method="post" asp-page-handler="WipeAll" class="filter-form"
          data-confirm="This permanently deletes every stored report and every forced-report row. This is irreversible — there is no undo."
          data-confirm-title="Wipe all data" data-confirm-label="Wipe everything">
        @Html.AntiForgeryToken()
        <label>
            <span>Type <code>WIPE</code> to confirm</span>
            <input name="confirm" required pattern="WIPE" placeholder="WIPE" autocomplete="off" />
        </label>
        <button type="submit" class="danger">Wipe everything</button>
    </form>
</section>

@section Scripts {
    <script src="~/js/maintenance.js" asp-append-version="true"></script>
}
