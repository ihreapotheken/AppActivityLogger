@page
@model RSAAnalyticsSessionModel
@using ReportService.Admin.ViewModels
@{
    ViewData["Title"] = $"Session {Model.Id}";
}
@await Html.PartialAsync("_PageHeader", new RSAPageHeaderVM("Session timeline", $"Events recorded for session {Model.Id} on {Model.Platform}."))

<p class="muted">
    <a asp-page="/AnalyticsSessions">← back to sessions</a>
    · <a asp-page="/AnalyticsEvents" asp-route-session="@Model.Id">filter events for this session →</a>
</p>

@if (Model.Timeline.Count == 0)
{
    <empty-state>No events found for this session. It may have been purged by retention.</empty-state>
}
else
{
    <table>
        <thead>
            <tr>
                <th scope="col" tip="Position of the event in the session timeline (1 = first)." sort="num">#</th>
                <th scope="col" tip="Local time the event was recorded on the device." sort="date">Occurred</th>
                <th scope="col" tip="Event category (e.g. screen_view, action, lifecycle)." sort="text">Type</th>
                <th scope="col" tip="Event name reported by the SDK." sort="text">Name</th>
                <th scope="col" tip="Screen the event occurred on, or em-dash if none." sort="text">Screen</th>
                <th scope="col" tip="Feature area associated with the event, or em-dash if none." sort="text">Feature</th>
                <th scope="col" tip="Event duration in milliseconds, or em-dash if not measured." sort="num">Duration</th>
            </tr>
        </thead>
        <tbody>
        @{ var i = 0; }
        @foreach (var e in Model.Timeline)
        {
            i++;
            <tr>
                <td data-sort-value="@i">@i</td>
                <td class="mono" data-sort-value="@e.OccurredAt.UtcDateTime.ToString("o")">@e.OccurredAt.AsLocalTime()</td>
                <td class="mono">@e.Type</td>
                <td class="mono">@e.Name</td>
                <td class="mono">@(e.Screen ?? "—")</td>
                <td class="mono">@(e.Feature ?? "—")</td>
                <td data-sort-value="@(e.DurationMs ?? -1)">@(e.DurationMs is { } ms ? ms.ToString("N0") + " ms" : "—")</td>
            </tr>
        }
        </tbody>
    </table>
}
