@page
@model RSAAuditModel
@{
    ViewData["Title"] = "Audit";
}
<h1>Audit log</h1>
<p class="muted">Most recent 200 admin events (login success/failure, delete, rebuild, integrity, vacuum, backup, export).</p>

@if (Model.Entries.Count == 0)
{
    <p class="muted">No audit entries yet — or the audit DB isn't writable.</p>
}
else
{
    <table>
        <thead>
            <tr><th>At (UTC)</th><th>Actor</th><th>Remote</th><th>Action</th><th>Target</th><th>Result</th><th>Details</th></tr>
        </thead>
        <tbody>
            @foreach (var e in Model.Entries)
            {
                <tr>
                    <td class="mono">@e.At.AsLocalTime()</td>
                    <td class="mono">@e.Actor</td>
                    <td class="mono">@e.RemoteAddress</td>
                    <td class="mono">@e.Action</td>
                    <td class="mono">@(e.Target ?? "—")</td>
                    <td>
                        @if (e.Success)
                        {
                            <span class="badge badge-ok">ok</span>
                        }
                        else
                        {
                            <span class="badge badge-bad">fail</span>
                        }
                    </td>
                    <td>@(e.Details ?? "")</td>
                </tr>
            }
        </tbody>
    </table>
}
