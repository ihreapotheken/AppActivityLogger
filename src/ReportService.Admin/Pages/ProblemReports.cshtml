@page
@model RSAProblemReportsModel
@using ReportService.Admin.ViewModels
@{
    ViewData["Title"] = "Problem reports";
    var filter = Model.Filter;
    var vm = Model.Listing;
    var rowDeleteUrl = $"/ProblemReports{filter.ToQueryString(1)}&handler=DeleteOne";
}
@await Html.PartialAsync("_PageHeader", new RSAPageHeaderVM(
    "Problem reports",
    "User-initiated Report-a-Problem submissions with attached logs. Crash auto-uploads (Errors) and analytics events live in their own sections."))

<hint-box docs-href="/Documentation#01-overview--report-a-problem">
    <p>
        These are bug reports a user <em>chose</em> to send from inside the app via the SDK's
        "Report a Problem" feature — each one is a JSON document, often with a gzip-compressed
        <strong>log bundle</strong> attached. The tiles summarise the current filter; the table lists the
        newest submissions first, and each <strong>file</strong> link opens the decoded report and its logs.
        Automatic crash uploads are not shown here — they live on the <a asp-page="/Errors">Errors</a> page.
    </p>
</hint-box>

@{ var sum = Model.Summary; }
<section class="tiles" aria-label="Analytics for the current filter">
    <tile label="Matching reports">@sum.Total.ToString("N0")</tile>
    <tile label="Android · iOS">@sum.Android.ToString("N0") · @sum.Ios.ToString("N0")</tile>
    <tile label="Multipart · JSON">@sum.Multipart.ToString("N0") · @sum.Json.ToString("N0")</tile>
    <tile label="With logs">@sum.WithAttachment.ToString("N0")</tile>
    <tile label="JSON bytes">@RSAByteFormatter.Format(sum.TotalBytes)</tile>
    <tile label="Attachment bytes">@RSAByteFormatter.Format(sum.AttachmentBytes)</tile>
</section>
@if (sum.Truncated)
{
    <p class="muted">Breakdown computed from the most recent 2,000 matches; the “matching reports” total is exact. Narrow the filter for an exact breakdown.</p>
}

<h2>Submissions</h2>
@await Html.PartialAsync("_ReportsFilter", new RSAReportsFilterPanelVM(
    "/ProblemReports",
    filter,
    Model.AvailablePlatforms,
    ShowChannelFilter: false,
    ShowAttachmentFilter: false))

@section Scripts {
    <script src="~/js/auto-submit.js" asp-append-version="true"></script>
}

<span id="list" class="list-anchor"></span>
<p class="muted">
    @vm.TotalMatched matching submission@(vm.TotalMatched == 1 ? "" : "s") · page @vm.PageNumber of @vm.TotalPages
    · source: <span class="mono">@(vm.UsedIndex ? "sqlite index" : "filesystem scan")</span>
</p>

@await Html.PartialAsync("_DeleteFilteredBar", new RSADeleteBarVM(
    $"/ProblemReports{filter.ToQueryString(1)}&handler=DeleteMatching", vm.TotalMatched, "problem report"))

@if (vm.Items.Count == 0)
{
    <empty-state>No user-submitted problem reports match the current filter. Submissions appear here when the SDK posts to <code>/partners/api/v2/report-problem</code> with a non-crash <code>kind</code>.</empty-state>
}
else
{
    <table>
        <thead>
            <tr>
                <th scope="col" tip="Local time the user submitted this report-a-problem to the service">Submitted</th>
                <th scope="col" tip="Originating SDK platform (android or ios)">Platform</th>
                <th scope="col" tip="Client (tenant) and app this report is attributed to">Client / App</th>
                <th scope="col" tip="Stored report file name; links to the full decoded report detail view">File</th>
                <th scope="col" tip="Size of the attached log bundle, or — when the submission included no logs">Attachment</th>
                <th scope="col" tip="Parsed log entries: total count plus per-level and http-event chip breakdown">Log entries</th>
                <th scope="col" aria-label="Delete"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in vm.Items)
            {
                <tr>
                    <td class="mono">@r.SubmittedAt.AsLocalTime()</td>
                    <td class="mono">@r.Platform</td>
                    <td class="mono">@(r.ClientId ?? "—") / @(r.AppId ?? "—")</td>
                    <td class="mono"><a asp-page="/Report" asp-route-platform="@r.Platform" asp-route-fileName="@r.FileName">@r.FileName</a></td>
                    <td>@(r.AttachmentFileName is null ? Html.Raw("<span class=\"muted\">— (no logs)</span>") : Html.Raw(RSAByteFormatter.Format(r.AttachmentSizeBytes)))</td>
                    <td>
                        @if (r.LogSummary is { } s)
                        {
                            <span class="mono">@s.TotalEntries</span>
                            <span class="muted small">
                                @foreach (var kv in s.ByLevel.OrderByDescending(kv => kv.Value).Take(4))
                                {
                                    <span class="chip chip-loglevel chip-loglevel-@kv.Key.ToLowerInvariant()">@kv.Key.ToLowerInvariant()&nbsp;@kv.Value</span>
                                }
                                @if (s.HttpEventCount > 0)
                                {
                                    <span class="chip">http&nbsp;@s.HttpEventCount</span>
                                }
                            </span>
                        }
                        else if (r.AttachmentFileName is null)
                        {
                            <span class="muted">—</span>
                        }
                        else
                        {
                            <span class="muted">— (encrypted or not parsed)</span>
                        }
                    </td>
                    <td>@await Html.PartialAsync("_RowDelete", new RSARowDeleteVM(rowDeleteUrl, r.Platform, r.FileName))</td>
                </tr>
            }
        </tbody>
    </table>

    @await Html.PartialAsync("_Pager", new RSAPagerVM(
        vm.PageNumber > 1 ? filter.ToQueryString(vm.PageNumber - 1) : null,
        vm.PageNumber < vm.TotalPages ? filter.ToQueryString(vm.PageNumber + 1) : null,
        $"page {vm.PageNumber} / {vm.TotalPages}"))
}
