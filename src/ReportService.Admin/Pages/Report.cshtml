@page "/Report/{platform}/{fileName}"
@model RSAReportModel
@{
    ViewData["Title"] = $"{Model.Platform} · {Model.FileName}";
    var s = Model.Summary;
    // "All reports" was retired; route the platform crumb to the listing that actually contains this
    // report — crashes live in Errors, everything else in Problem reports.
    var listingPage = string.Equals(s.Kind, "crash", StringComparison.OrdinalIgnoreCase) ? "/Errors" : "/ProblemReports";
}
<div class="crumbs">
    <a asp-page="/Index">Dashboard</a> /
    <a asp-page="@listingPage" asp-route-platform="@Model.Platform">@Model.Platform</a> /
    <span class="mono">@Model.FileName</span>
</div>

<header class="report-header">
    <h1 class="report-title">@(s.Title ?? Model.FileName)</h1>
    <div class="chips" aria-label="Report tags">
        <span class="chip chip-platform">@Model.Platform</span>
        @if (!string.IsNullOrEmpty(Model.ClientId))
        {
            <span class="chip chip-tenant">client · @Model.ClientId</span>
        }
        @if (!string.IsNullOrEmpty(Model.AppId))
        {
            <span class="chip chip-tenant">app · @Model.AppId</span>
        }
        @if (!string.IsNullOrEmpty(Model.IngestionChannel))
        {
            <span class="chip chip-channel">channel · @Model.IngestionChannel</span>
        }
        @if (Model.AttachmentFileName is not null)
        {
            <span class="chip chip-attachment">attachment</span>
        }
    </div>
    <p class="muted report-meta">
        Submitted <span class="mono">@Model.SubmittedAt.AsLocalTime()</span>
        · <span class="mono">@Model.SizeBytes bytes</span>
        @if (Model.AttachmentFileName is not null)
        {
            <text> · <span class="mono">@Model.AttachmentFileName</span></text>
        }
    </p>
</header>

@if (!string.IsNullOrEmpty(s.Message) || !string.IsNullOrEmpty(s.DeviceModel) || !string.IsNullOrEmpty(s.AppVersion))
{
    <section class="card report-card">
        <h2>Summary</h2>
        @if (!string.IsNullOrEmpty(s.Message))
        {
            <p class="report-message">@s.Message</p>
        }
        <dl class="summary-grid">
            @{ void Row(string label, string? value, string? css = null) {
                if (!string.IsNullOrEmpty(value))
                {
                    <text>
                        <dt>@label</dt>
                        <dd class="@css">@value</dd>
                    </text>
                }
            } }
            @{ Row("Client", Model.ClientId, "mono"); }
            @{ Row("App", Model.AppId, "mono"); }
            @{ Row("Device", s.DeviceModel, "mono"); }
            @{ Row("App version", s.AppVersion, "mono"); }
            @{ Row("Source", s.Source); }
            @{ Row("Pharmacy", s.PharmacyId, "mono"); }
            @{ Row("Importance", s.FunctionalityImportance); }
            @{ Row("Email", s.Email, "mono"); }
            @{ Row("Phone", s.PhoneNumber, "mono"); }
            @if (s.Labels is { Count: > 0 } labels)
            {
                <dt>Labels</dt>
                <dd>
                    @foreach (var l in labels)
                    {
                        <span class="chip chip-label">@l</span>
                    }
                </dd>
            }
        </dl>
    </section>
}

@if (!string.IsNullOrEmpty(Model.StackTrace))
{
    <section class="card report-card">
        <h2>Stack trace</h2>
        @if (Model.DeobfuscatedStackTrace is { } deob)
        {
            <p class="muted small">
                <span class="chip">deobfuscated · @Model.RewrittenFrameCount frame@(Model.RewrittenFrameCount == 1 ? "" : "s")</span>
                @Model.AppliedMappingSummary — applied in memory, not stored. Refresh to return to the obfuscated view.
            </p>
            <pre class="report stack">@deob</pre>
            <details class="muted small">
                <summary>Show original obfuscated trace</summary>
                <pre class="report stack">@Model.StackTrace</pre>
            </details>
        }
        else
        {
            <pre class="report stack">@Model.StackTrace</pre>
        }
    </section>
}

@if (Model.LogSummary is { } logSummary)
{
    <section class="card report-card">
        <h2>Log attachment summary</h2>
        <p class="muted">Extracted at ingest from the gzip attachment (iOS plaintext <code>LogEntry</code> array). Counts per level + total HTTP events; the raw attachment is downloadable above.</p>
        <div class="tiles tiles-compact">
            <tile label="Total entries">@logSummary.TotalEntries.ToString("N0")</tile>
            <tile label="HTTP events">@logSummary.HttpEventCount.ToString("N0")</tile>
            @if (logSummary.Earliest is { } e1 && logSummary.Latest is { } e2)
            {
                <tile label="Window" value-class="mono">@((e2 - e1).ToString(@"hh\:mm\:ss"))</tile>
            }
        </div>
        @if (logSummary.ByLevel.Count > 0)
        {
            <h3 class="logcat-overview-h">By level</h3>
            <div class="chips">
                @foreach (var kv in logSummary.ByLevel.OrderByDescending(kv => kv.Value))
                {
                    <span class="chip chip-loglevel chip-loglevel-@kv.Key.ToLowerInvariant()">@kv.Key.ToLowerInvariant()&nbsp;@kv.Value</span>
                }
            </div>
        }
    </section>
}

<section class="card report-card">
    <h2>Full JSON</h2>
    <pre class="report">@Model.JsonBody</pre>
</section>

@* Per-report ephemeral deobfuscation — the operator drops a mapping.txt here, the page parses
   + applies it in memory, and re-renders with symbolic frames. Nothing is written to disk,
   nothing is shared with the next viewer. Optional SDK consumer mapping for chained retrace.
   Only shown when there's something to deobfuscate (a stack trace or an attached log) — a plain
   report with no crash log attached has nothing to rewrite. *@
@if (Model.CanDeobfuscate)
{
<section class="card report-card">
    <h2>Deobfuscate this report</h2>
    <p class="muted small">
        Apply an R8 <code>mapping.txt</code> to this report's stack trace and logcat. The
        mapping is parsed in memory and never persisted — refreshing the page returns to the
        obfuscated view. For chained retrace (host + pre-minified SDK), drop the SDK's
        consumer mapping into the second field as well.
    </p>
    @if (Model.AppliedMappingSummary is { } applied)
    {
        <div class="flash flash-ok" role="status">
            <span class="chip">deobfuscated · @Model.RewrittenFrameCount frame@(Model.RewrittenFrameCount == 1 ? "" : "s")</span>
            applied <span class="mono">@applied</span> to this view (in memory; refresh to revert).
        </div>
    }
    @if (TempData["Flash"] is string flash)
    {
        <div class="flash flash-err" role="status">@flash</div>
    }
    <form method="post" asp-page-handler="Deobfuscate" enctype="multipart/form-data" class="filter-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="platform" value="@Model.Platform" />
        <input type="hidden" name="fileName" value="@Model.FileName" />
        <label>
            <span>Host mapping.txt</span>
            <input type="file" name="hostMapping" accept=".txt,text/plain" required />
        </label>
        <label>
            <span>SDK consumer mapping.txt (optional)</span>
            <input type="file" name="consumerMapping" accept=".txt,text/plain" />
        </label>
        <button type="submit" class="primary">Deobfuscate</button>
    </form>
</section>
}

@if (Model.AttachmentFileName is not null)
{
    <section class="card report-card">
        <h2>Attachment log</h2>
        @if (!Model.LogcatAvailable)
        {
            <p class="muted">@(Model.LogcatNotice ?? "No log content to display.")</p>
        }
        else
        {
            @if (Model.LogcatNotice is { } notice)
            {
                <p class="muted">@notice</p>
            }
            @if (Model.LogcatOverview is { } ov)
            {
                <section class="logcat-overview" aria-label="Log summary">
                    <div class="tiles tiles-compact">
                        <tile label="Total lines">@ov.TotalLines.ToString("N0")</tile>
                        <tile label="Errors" variant="error">@ov.ErrorCount.ToString("N0")</tile>
                        <tile label="Warnings" variant="warn">@ov.WarnCount.ToString("N0")</tile>
                        <tile label="Info">@ov.InfoCount.ToString("N0")</tile>
                        <tile label="Debug">@ov.DebugCount.ToString("N0")</tile>
                        <tile label="Verbose">@ov.VerboseCount.ToString("N0")</tile>
                    </div>
                    @if (ov.FirstTimestamp is not null || ov.LastTimestamp is not null)
                    {
                        <p class="muted">
                            Range:
                            <span class="mono">@(ov.FirstTimestamp ?? "?")</span> →
                            <span class="mono">@(ov.LastTimestamp ?? "?")</span>
                        </p>
                    }
                    @if (ov.FirstErrors.Count > 0)
                    {
                        <h3 class="logcat-overview-h">First @(ov.FirstErrors.Count) error line@(ov.FirstErrors.Count == 1 ? "" : "s")</h3>
                        <pre class="report stack logcat-first-errors" aria-label="First error lines">@foreach (var line in ov.FirstErrors)
{<text>#@line.Number  @line.Text
</text>}</pre>
                    }
                </section>
            }
            <details class="logcat-details" id="log" @(Model.HasLogFilter || Model.LogPageNumber > 1 ? "open" : null)>
                <summary>Full attachment log (@Model.LogTotalLines.ToString("N0") lines) — expand to view, filter, or search</summary>
                @* Server-side filter: a GET form (like every other listing) reloads with the level +
                   search as query params, so only the matching page of lines is sent to the browser. *@
                <form method="get" class="logcat-controls" role="search" aria-label="Logcat filter"
                      asp-page="/Report" asp-route-platform="@Model.Platform" asp-route-fileName="@Model.FileName">
                    <label>Level
                        <select name="logLevel" aria-label="Log level filter">
                            @foreach (var lvl in new[] { "", "error", "warn", "info", "debug", "verbose", "other" })
                            {
                                <option value="@lvl" selected="@(string.Equals(Model.LogLevel ?? "", lvl, StringComparison.Ordinal))">@(lvl.Length == 0 ? "all" : lvl)</option>
                            }
                        </select>
                    </label>
                    <label>Search (case-insensitive substring or /regex/)
                        <input type="text" name="logSearch" value="@Model.LogSearch" placeholder="e.g. NullPointer  or  /pharmacyId=\d+/" />
                    </label>
                    <button type="submit" class="primary">Filter</button>
                    @if (Model.HasLogFilter)
                    {
                        <a class="btn" asp-page="/Report" asp-route-platform="@Model.Platform" asp-route-fileName="@Model.FileName">Clear</a>
                    }
                    <span class="logcat-count muted">
                        @(Model.HasLogFilter
                            ? $"{Model.LogMatchCount:N0} of {Model.LogTotalLines:N0} lines"
                            : $"{Model.LogTotalLines:N0} lines")
                    </span>
                </form>
                @if (Model.LogMatchCount == 0)
                {
                    <empty-state>No log lines match this filter.</empty-state>
                }
                else
                {
                    @if (Model.LogTotalPages > 1)
                    {
                        var firstLine = ((Model.LogPageNumber - 1) * RSAReportModel.LogPageSize) + 1;
                        var lastLine = Math.Min(Model.LogPageNumber * RSAReportModel.LogPageSize, Model.LogMatchCount);
                        <p class="muted">Showing @firstLine.ToString("N0")–@lastLine.ToString("N0") of @Model.LogMatchCount.ToString("N0") matching lines · page @Model.LogPageNumber / @Model.LogTotalPages</p>
                    }
                    <pre class="logcat" aria-label="Logcat content"><code>@foreach (var line in Model.LogcatPage)
{<text><span class="logcat-line logcat-@line.Level"><span class="logcat-num">@line.Number</span><span class="logcat-text">@line.Text</span></span>
</text>}</code></pre>
                    @if (Model.LogTotalPages > 1)
                    {
                        @await Html.PartialAsync("_Pager", new RSAPagerVM(
                            Model.LogPageNumber > 1 ? Model.BuildLogHref(Model.LogPageNumber - 1) : null,
                            Model.LogPageNumber < Model.LogTotalPages ? Model.BuildLogHref(Model.LogPageNumber + 1) : null,
                            $"page {Model.LogPageNumber} / {Model.LogTotalPages}",
                            AriaLabel: "Log pagination"))
                    }
                }
            </details>
        }
    </section>
}

<div class="actions">
    <a class="btn" asp-page-handler="DownloadJson" asp-route-platform="@Model.Platform" asp-route-fileName="@Model.FileName">Download JSON</a>
    @if (Model.AttachmentFileName is not null)
    {
        <a class="btn" asp-page-handler="DownloadAttachment" asp-route-platform="@Model.Platform" asp-route-fileName="@Model.FileName">Download gzip</a>
    }
    <form method="post" asp-page-handler="Delete" class="inline"
          data-confirm="Permanently delete @Model.FileName and its attachment? This cannot be undone."
          data-confirm-label="Delete report">
        @Html.AntiForgeryToken()
        <input type="hidden" name="platform" value="@Model.Platform" />
        <input type="hidden" name="fileName" value="@Model.FileName" />
        <button type="submit" class="danger">Delete</button>
    </form>
</div>

