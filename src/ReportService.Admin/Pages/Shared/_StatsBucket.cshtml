@*
    Renders one Top-N table for the Stats page with built-in pagination. Each row links into
    /Reports filtered by the bucket's column so the operator can drill from "top N pharmacies"
    straight to the matching report list. The parent page supplies prev/next URLs so it can
    preserve every other bucket's page state in the query string.
*@
@using ReportService.Admin.ViewModels
@using ReportService.Storage
@model RSAStatsBucketArgs
@{
    var items = Model.Items;
    var page = Math.Max(1, Model.Page);
    var pageSize = Math.Max(1, Model.PageSize);
    var totalPages = items.Count == 0 ? 1 : (int)Math.Ceiling(items.Count / (double)pageSize);
    if (page > totalPages) page = totalPages;
    var slice = items.Skip((page - 1) * pageSize).Take(pageSize).ToArray();
    var max = items.Count == 0 ? 1 : Math.Max(1, items.Max(b => b.Count));
}
<section class="card stats-card">
    <h2>@Model.Title</h2>
    @if (items.Count == 0)
    {
        <empty-state>No data.</empty-state>
    }
    else
    {
        <table class="stats-table">
            <thead>
                <tr>
                    <th scope="col" tip="The value being counted — device model, pharmacy, app version, platform or channel (see the card title).">Key</th>
                    <th scope="col" tip="Number of reports in the window attributed to this value.">Count</th>
                    <th scope="col" class="bar-col"></th>
                    <th scope="col"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in slice)
                {
                    var pct = (int)Math.Round(b.Count * 100.0 / max);
                    var tip = $"{b.Key}: {b.Count} ({pct}% of the top result)";
                    <tr>
                        <td class="mono">@b.Key</td>
                        <td>@b.Count</td>
                        @* SVG rect width is an attribute, not an inline style, so it isn't blocked by the admin CSP (style-src 'self'). data-chart-tip wires the shared hover tooltip. *@
                        <td class="bar-col"><svg class="hbar" viewBox="0 0 100 8" preserveAspectRatio="none" data-chart-tip="@tip" role="img" aria-label="@tip"><rect class="hbar-fill" x="0" y="0" width="@pct" height="8"></rect></svg></td>
                        <td>
                            @if (b.Key != "(unset)" && !string.IsNullOrEmpty(Model.FilterParam))
                            {
                                <a asp-page="/Reports" asp-route-@Model.FilterParam="@b.Key">filter</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (totalPages > 1)
        {
            @await Html.PartialAsync("_Pager", new RSAPagerVM(
                page > 1 ? Model.BuildHref(page - 1) : null,
                page < totalPages ? Model.BuildHref(page + 1) : null,
                $"page {page} / {totalPages}",
                AriaLabel: $"{Model.Title} pagination",
                ExtraClass: "bucket-pager"))
        }
    }
</section>

