@inject ReportService.Options.RSCReportServiceOptions ServiceOptions
@{
    var title = ViewData["Title"] as string ?? "Reports";
    var user = User?.Identity?.Name;
    var authed = User?.Identity?.IsAuthenticated == true;
    // "Admin" (operator) vs "client login": an operator cookie (the /Login admin key, or the localhost
    // dev-operator) carries no rsc:client_id claim; a /ClientLogin session does. The OPERATIONS section
    // — tenant administration (clients/apps/keys), Maintenance, Audit — is admin-only, so it is hidden
    // from client logins (which are already confined server-side to their own analytics dashboards by
    // RSAClientLoginScope; this just removes the dead nav links from their view).
    var isClientLogin = User?.FindFirst(ReportService.Security.RSCTenantClaims.ClientId)?.Value is { Length: > 0 };
    var isAdmin = authed && !isClientLogin;
    // Loopback (localhost) requests are auto-signed-in by Program.cs as the synthetic dev-operator;
    // signing out is meaningless because the next request re-authenticates and no cookie was ever set.
    // Detect that principal by its identity name — the RemoteIpAddress is NOT reliably loopback in the
    // docker-compose dev stack (Kestrel sees the bridge gateway), whereas the name is exact. Hide the
    // sign-out button for it so localhost operators don't see a control that does nothing.
    var isDevOperator = string.Equals(user, ReportService.Admin.Options.RSAAdminOptions.DevOperatorName, StringComparison.Ordinal);
    var env = string.IsNullOrWhiteSpace(ServiceOptions.Environment) ? "production" : ServiceOptions.Environment;
    var envIsProd = string.Equals(env, "production", StringComparison.OrdinalIgnoreCase);

    // Highlight the active sidebar link. ViewContext.RouteData.Values["page"] holds the current
    // Razor page route ("/ProblemReports", "/Index", etc.); comparing against each link's target keeps
    // the active state in lockstep with where the user actually is.
    var currentPage = (ViewContext.RouteData.Values["page"] as string) ?? string.Empty;
    string Active(string pageRoute) =>
        string.Equals(currentPage, pageRoute, StringComparison.OrdinalIgnoreCase) ? "is-active" : string.Empty;

    // Label of the currently-selected nav "tab", shown next to the logo. Mirrors the sidebar link
    // captions below; sub-pages that aren't themselves nav entries fall back to their page title.
    var currentLabel = currentPage switch
    {
        "/Index" => "Dashboard",
        "/Stats" => "Stats",
        "/Analytics" => "Analytics",
        "/AnalyticsRetention" => "Retention",
        "/AnalyticsFunnels" => "Funnels",
        "/ProblemReports" => "Problem reports",
        "/Errors" => "Error reports",
        "/Report" => "Report details",
        "/DeepLinks" => "Deep links",
        "/Clients" => "Clients & apps",
        "/Maintenance" => "Maintenance",
        "/ApiConsole" => "API console",
        "/Audit" => "Audit log",
        "/Status" => "Status",
        "/ApiDocs" => "API docs",
        "/Docs" => "Docs",
        _ => title,
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>@title · Reports</title>
    @* Inline SVG favicon — avoids a 404 on /favicon.ico and needs no static asset. *@
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Crect width='16' height='16' rx='3' fill='%23d43034'/%3E%3Cpath d='M4 4h6l2 2v6H4z' fill='none' stroke='white' stroke-width='1.3'/%3E%3C/svg%3E" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
</head>
<body class="@(authed ? "shell" : "shell-anon")">
    <a href="#main" class="visually-hidden">Skip to content</a>
    @if (authed)
    {
        @* Mobile-only top bar: the sidebar collapses to an off-canvas drawer on small screens. *@
        <header class="mobile-bar">
            <button type="button" class="nav-toggle" aria-label="Open navigation" aria-controls="app-sidebar" aria-expanded="false">
                <span class="nav-toggle-bars" aria-hidden="true"></span>
            </button>
            <a class="mobile-brand" href="/" aria-label="Ihre Apotheken — home">@await Html.PartialAsync("_BrandLogo")</a>
            <span class="mobile-bar-title">@currentLabel</span>
        </header>
        <aside class="app-sidebar" id="app-sidebar" aria-label="Primary navigation">
            <a class="brand" href="/" aria-label="Ihre Apotheken — home">
                @await Html.PartialAsync("_BrandLogo")
                <span class="brand-text">
                    <span class="brand-page">@currentLabel</span>
                </span>
            </a>

            @* Replaces the static environment chip: the tenant/app switcher that drives the
               persistent per-app dashboard scope (clients+apps for operators, own apps for a client login). *@
            @await Component.InvokeAsync("TenantSwitcher")

            <nav class="side-nav" aria-label="Sections">
                <div class="side-section">
                    <h2 class="side-heading">Insights</h2>
                    <a class="@Active("/Index")" asp-page="/Index">Dashboard</a>
                    <a class="@Active("/Stats")" asp-page="/Stats">Stats</a>
                </div>

                <div class="side-section">
                    <h2 class="side-heading">Submissions</h2>
                    <a class="@Active("/ProblemReports")"     asp-page="/ProblemReports">Problem reports</a>
                    <a class="@Active("/Errors")"             asp-page="/Errors">Error reports</a>
                    @* Single Analytics entry — Overview/Sales/Retention/Funnels are sub-tabs (_AnalyticsNav),
                       not separate sidebar items. Stays highlighted across every /Analytics* sub-page. *@
                    <a class="@(currentPage.StartsWith("/Analytics", StringComparison.OrdinalIgnoreCase) ? "is-active" : null)" asp-page="/Analytics">Analytics</a>
                    <a class="@Active("/DeepLinks")"          asp-page="/DeepLinks">Deep links</a>
                </div>

                @* OPERATIONS is admin-only: tenant administration + ops tooling. Hidden entirely from
                   client logins (they have no business managing clients/apps/keys, and are confined
                   server-side anyway). The dev-operator and real operator logins both see it. *@
                @if (isAdmin)
                {
                    <div class="side-section">
                        <h2 class="side-heading">Operations</h2>
                        @* Client/app/API-key administration — one merged screen: register clients +
                           mint/issue their keys, manage each client's apps, and mint/revoke managed API keys. *@
                        <a class="@Active("/Clients")"       asp-page="/Clients">Clients &amp; apps</a>
                        @* Forced reports hidden from nav for now (page still reachable at /ForcedReports). *@
                        <a class="@Active("/Maintenance")"   asp-page="/Maintenance">Maintenance</a>
                        @* In-dashboard API request runner (Hoppscotch-style) over the bundled collection. *@
                        <a class="@Active("/ApiConsole")"    asp-page="/ApiConsole">API console</a>
                        <a class="@Active("/Audit")"         asp-page="/Audit">Audit log</a>
                    </div>
                }

                <div class="side-section">
                    <h2 class="side-heading">System</h2>
                    <a class="@Active("/Status")"  asp-page="/Status">Status</a>
                    <a class="@Active("/ApiDocs")" asp-page="/ApiDocs">API docs</a>
                    <a class="@Active("/Docs")"    asp-page="/Docs">Docs</a>
                </div>
            </nav>

            <div class="side-footer">
                <span class="user" aria-label="Signed in as">@user</span>
                @if (!isDevOperator)
                {
                    <form method="post" action="/Logout" class="inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="link" aria-label="Sign out">sign out</button>
                    </form>
                }
            </div>
        </aside>
        <div class="nav-backdrop" hidden></div>
    }
    else
    {
        <header class="app-header">
            <div class="bar">
                <a class="brand" href="/" aria-label="Ihre Apotheken — home">
                    @await Html.PartialAsync("_BrandLogo")
                </a>
                <span class="env-badge env-@env.ToLowerInvariant()" title="ReportService:Environment" aria-label="Environment">@env</span>
            </div>
        </header>
    }
    <main id="main">
        @await Html.PartialAsync("_FlashBanner")
        @RenderBody()
    </main>
    @if (!authed)
    {
        <footer>
            <small>Reports · operator console</small>
        </footer>
    }
    @await Html.PartialAsync("_ConfirmDialog")
    <script src="~/js/local-time.js" asp-append-version="true"></script>
    <script src="~/js/sortable-tables.js" asp-append-version="true"></script>
    <script src="~/js/header-tooltips.js" asp-append-version="true"></script>
    <script src="~/js/chart-tooltips.js" asp-append-version="true"></script>
    <script src="~/js/chart-tabs.js" asp-append-version="true"></script>
    <script src="~/js/nav-drawer.js" asp-append-version="true"></script>
    <script src="~/js/confirm-dialog.js" asp-append-version="true"></script>
    <script src="~/js/tenant-switcher.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
