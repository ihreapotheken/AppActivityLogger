@*
    Client → app → environment scope selector for the analytics pages. The client is the top-level
    tenant; apps are nested under it, so the App dropdown lists only the selected client's apps and the
    Environment dropdown lists only the selected app's environments (the selector round-trips on change
    via GET, so the dependent dropdowns refresh server-side). The empty option means "all". The active
    platform tab rides along in a hidden field. For a client login, only that client + its apps are in
    the VM, so the Client dropdown is effectively fixed to them.
*@
@model ReportService.Admin.ViewModels.RSATenantScopeVM
@{
    // A client login carries a client_id claim and is pinned to its own client by the scope
    // middleware: render the client as a fixed label rather than a dropdown listing every client.
    var clientLogin = User?.FindFirst(ReportService.Security.RSCTenantClaims.ClientId)?.Value;
    var isClientLogin = !string.IsNullOrEmpty(clientLogin);

    // Apps shown depend on the chosen client; envs shown depend on the chosen app (else the union).
    var shownApps = string.IsNullOrEmpty(Model.CurrentClient)
        ? Model.Apps
        : Model.Apps.Where(a => a.ClientSlug == Model.CurrentClient).ToList();
    var envSource = string.IsNullOrEmpty(Model.CurrentApp)
        ? shownApps
        : shownApps.Where(a => a.Slug == Model.CurrentApp).ToList();
    var envs = envSource.SelectMany(a => a.Environments).Distinct(StringComparer.Ordinal).OrderBy(e => e, StringComparer.Ordinal);
}
<form class="tenant-scope filters" method="get" asp-page="@Model.PageName" data-auto-submit aria-label="Tenant scope">
    <input type="hidden" name="platform" value="@Model.CurrentPlatform" />
    @if (isClientLogin)
    {
        <label>
            <span>Client</span>
            <input type="hidden" name="client" value="@clientLogin" />
            <input type="text" value="@clientLogin" readonly aria-label="Client" />
        </label>
    }
    else
    {
        <label>
            <span>Client</span>
            <select name="client">
                <option value="">All clients</option>
                @foreach (var c in Model.Clients)
                {
                    <option value="@c.Slug" selected="@(c.Slug == Model.CurrentClient)">@c.DisplayName</option>
                }
            </select>
        </label>
    }
    <label>
        <span>App</span>
        <select name="app">
            <option value="">All apps</option>
            @foreach (var a in shownApps)
            {
                var label = string.IsNullOrEmpty(Model.CurrentClient) ? $"{a.DisplayName} ({a.ClientSlug})" : a.DisplayName;
                <option value="@a.Slug" selected="@(a.Slug == Model.CurrentApp)">@label</option>
            }
        </select>
    </label>
    <label>
        <span>Environment</span>
        <select name="env">
            <option value="">All environments</option>
            @foreach (var env in envs)
            {
                <option value="@env" selected="@(env == Model.CurrentEnv)">@env</option>
            }
        </select>
    </label>
    <noscript><button type="submit" class="primary">Apply</button></noscript>
</form>
