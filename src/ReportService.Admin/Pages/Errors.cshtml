@page
@model RSAErrorsModel
@using ReportService.Admin.ViewModels
@{
    ViewData["Title"] = "Errors";
    var scope = Model.CanonicalPlatform;
    var drilledIn = !string.IsNullOrEmpty(Model.Filter.TopFrame);
    var subtitle = drilledIn
        ? $"Crash reports matching this signature{(scope is null ? "" : $" on {scope}")}."
        : scope switch
        {
            "ios" => "iOS crashes and errors from ingested crash reports.",
            "android" => "Android crashes and errors from ingested crash reports.",
            _ => "Crashes and errors from ingested crash reports (iOS + Android).",
        };
    var heading = drilledIn ? "Signature detail" : "Error reporting";
}
@await Html.PartialAsync("_PageHeader", new RSAPageHeaderVM(heading, subtitle))

@if (!drilledIn)
{
<nav class="scope-tabs" aria-label="Platform scope">
    <a asp-page="/Errors" class="@(scope is null ? "active" : null)">All platforms</a>
    <a asp-page="/Errors" asp-route-platform="ios" class="@(scope == "ios" ? "active" : null)">iOS</a>
    <a asp-page="/Errors" asp-route-platform="android" class="@(scope == "android" ? "active" : null)">Android</a>
</nav>

<section class="tiles" aria-label="Error summary">
    <div class="tile">
        <div class="tile-label">Crashes (24h)</div>
        <div class="tile-value">@Model.Dashboard.CrashesLast24h.ToString("N0")</div>
    </div>
    <div class="tile">
        <div class="tile-label">Errors (24h)</div>
        <div class="tile-value">@Model.Dashboard.ErrorsLast24h.ToString("N0")</div>
    </div>
    <div class="tile">
        <div class="tile-label">Affected users</div>
        <div class="tile-value">@Model.Dashboard.AffectedUsers.ToString("N0")</div>
    </div>
</section>

<h2>Platforms</h2>
<table>
    <thead>
        <tr>
            <th scope="col">Platform</th>
            <th scope="col">Crashes (24h)</th>
            <th scope="col">Errors (24h)</th>
            <th scope="col">Affected users</th>
            <th scope="col"></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var p in Model.Dashboard.Platforms)
    {
        <tr>
            <td class="mono"><a asp-page="/Errors" asp-route-platform="@p.Name">@p.Name</a></td>
            <td>@p.CrashesLast24h.ToString("N0")</td>
            <td>@p.ErrorsLast24h.ToString("N0")</td>
            <td>@p.AffectedUsers.ToString("N0")</td>
            <td><a asp-page="/Reports" asp-route-platform="@p.Name">reports →</a></td>
        </tr>
    }
    </tbody>
</table>

<h2>Top error signatures</h2>
<p class="muted">Reports are bucketed by the topmost stack frame extracted at ingest@(scope is null ? null : $" on {scope}"). The "By channel" column shows the multipart (SDK) vs JSON (API) split for each fault site.</p>
<table>
    <thead>
        <tr>
            <th scope="col">Signature</th>
            <th scope="col">Occurrences</th>
            <th scope="col">By channel</th>
            <th scope="col">Affected users</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var e in Model.Dashboard.TopErrors)
    {
        <tr>
            <td class="mono"><a asp-page="/Errors" asp-route-platform="@scope" asp-route-topFrame="@e.Signature" title="Filter list below to this signature">@e.Signature</a></td>
            <td>@e.Occurrences.ToString("N0")</td>
            <td class="mono"><span class="chip chip-channel-m">m: @e.MultipartCount</span> <span class="chip chip-channel-j">j: @e.JsonCount</span></td>
            <td>@e.AffectedUsers.ToString("N0")</td>
        </tr>
    }
    </tbody>
</table>

<h2>Error rate · last 7 days</h2>
<table>
    <thead>
        <tr>
            @for (var i = Model.Dashboard.ErrorRateLast7Days.Count - 1; i >= 0; i--)
            {
                <th scope="col">@(i == 0 ? "today" : $"-{i}d")</th>
            }
        </tr>
    </thead>
    <tbody>
        <tr>
            @for (var i = Model.Dashboard.ErrorRateLast7Days.Count - 1; i >= 0; i--)
            {
                <td>@Model.Dashboard.ErrorRateLast7Days[i].ToString("N0")</td>
            }
        </tr>
    </tbody>
</table>

<details class="collapsible-section">
    <summary><h2>Recent errors <span class="muted small">(@Model.Dashboard.RecentErrors.Count)</span></h2></summary>
    @if (Model.Dashboard.RecentErrors.Count == 0)
    {
        <p class="muted">No errors reported yet.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th scope="col">When</th>
                    <th scope="col">Platform</th>
                    <th scope="col">Channel</th>
                    <th scope="col">Signature</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Dashboard.RecentErrors)
                {
                    <tr>
                        <td class="mono">@r.OccurredAt.AsLocalTime()</td>
                        <td class="mono"><a asp-page="/Errors" asp-route-platform="@r.Platform">@r.Platform</a></td>
                        <td class="mono">@(string.Equals(r.Channel, "json", StringComparison.OrdinalIgnoreCase)
                            ? Html.Raw("<span class=\"chip chip-channel-j\">json</span>")
                            : Html.Raw("<span class=\"chip chip-channel-m\">multipart</span>"))</td>
                        <td class="mono"><a asp-page="/Errors" asp-route-platform="@r.Platform" asp-route-topFrame="@r.Signature" title="Filter list below to this signature">@r.Signature</a></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</details>
} @* end @if (!drilledIn) *@

<h2>@(drilledIn ? "Matching reports" : "Error reports")</h2>
@await Html.PartialAsync("_ReportsFilter", new RSAReportsFilterPanelVM(
    "/Errors",
    Model.Filter,
    Model.AvailablePlatforms,
    ShowChannelFilter: true,
    ShowAttachmentFilter: false))

@section Scripts {
    <script src="~/js/auto-submit.js" asp-append-version="true"></script>
}

<p class="muted">
    @Model.Listing.TotalMatched matching crash report@(Model.Listing.TotalMatched == 1 ? "" : "s") · page @Model.Listing.PageNumber of @Model.Listing.TotalPages
    · source: <span class="mono">@(Model.Listing.UsedIndex ? "sqlite index" : "filesystem scan")</span>
</p>

@if (Model.Listing.Items.Count == 0)
{
    <p class="muted">No crash reports match the current filter. Crash auto-uploads arrive with <code>kind = "crash"</code>.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th scope="col">Submitted</th>
                <th scope="col">Platform</th>
                <th scope="col">Channel</th>
                <th scope="col">File</th>
                <th scope="col">Top frame</th>
                <th scope="col">Size</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model.Listing.Items)
            {
                <tr>
                    <td class="mono">@r.SubmittedAt.AsLocalTime()</td>
                    <td class="mono">@r.Platform</td>
                    <td>@await Html.PartialAsync("_ChannelBadge", r)</td>
                    <td class="mono"><a asp-page="/Report" asp-route-platform="@r.Platform" asp-route-fileName="@r.FileName">@r.FileName</a></td>
                    <td class="mono">@(r.TopFrame ?? "—")</td>
                    <td>@RSAByteFormatter.Format(r.SizeBytes)</td>
                </tr>
            }
        </tbody>
    </table>

    <nav class="pager" aria-label="Pagination">
        @if (Model.Listing.PageNumber > 1)
        {
            <a href="@Model.Filter.ToQueryString(Model.Listing.PageNumber - 1)">← previous</a>
        }
        <span class="muted">page @Model.Listing.PageNumber / @Model.Listing.TotalPages</span>
        @if (Model.Listing.PageNumber < Model.Listing.TotalPages)
        {
            <a href="@Model.Filter.ToQueryString(Model.Listing.PageNumber + 1)">next →</a>
        }
    </nav>
}
