@page
@model RSAAnalyticsRetentionModel
@using ReportService.Admin.ViewModels
@{
    ViewData["Title"] = "Analytics retention";
    string Pct(double v) => (v * 100).ToString("F1") + "%";
    string Bucket(double r) => r >= 0.80 ? "ret-c4" : r >= 0.60 ? "ret-c3" : r >= 0.40 ? "ret-c2" : r >= 0.20 ? "ret-c1" : "ret-c0";
}
@await Html.PartialAsync("_PageHeader", new RSAPageHeaderVM("Analytics retention", $"What fraction of each day's new users came back 1, 7, and 30 days later. Window: last {Model.WindowDays} days."))
@await Html.PartialAsync("_AnalyticsNav")
@await Html.PartialAsync("_TenantScope", Model.TenantScope)

<hint-box docs-href="/Documentation#05-analytics--reading-retention">
    <p>
        Retention measures whether new users come back. Users are grouped by the day they first appeared
        (their <em>cohort</em>). <strong>D1</strong> is the share of a cohort that returned the next day;
        <strong>D7</strong> and <strong>D30</strong> ask the same at 7 and 30 days. The weighted summary
        averages each figure only over cohorts old enough to have reached that day, so a cohort that
        installed yesterday isn't counted against D7 yet — the <em>cohorts used</em> count shows how much
        data sits behind each number.
    </p>
</hint-box>

<form method="get" class="filters" aria-label="Retention filters">
    <label>Platform
        <select name="platform">
            <option value="">all</option>
            @foreach (var p in Model.AvailablePlatforms)
            {
                <option value="@p" selected="@(string.Equals(Model.Platform, p, StringComparison.OrdinalIgnoreCase))">@p</option>
            }
        </select>
    </label>
    <button type="submit" class="primary">Apply</button>
</form>

<section class="card">
    <h2>Weighted summary</h2>
    <div class="ret-summary">
        <div class="ret-stat @Bucket(Model.Summary.Day1)">
            <div class="ret-k">D1 returned</div>
            <div class="ret-v">@Pct(Model.Summary.Day1)</div>
            <div class="ret-n">over @Model.Summary.CohortsUsedDay1.ToString("N0") cohorts</div>
        </div>
        <div class="ret-stat @Bucket(Model.Summary.Day7)">
            <div class="ret-k">D7 returned</div>
            <div class="ret-v">@Pct(Model.Summary.Day7)</div>
            <div class="ret-n">over @Model.Summary.CohortsUsedDay7.ToString("N0") cohorts</div>
        </div>
        <div class="ret-stat @Bucket(Model.Summary.Day30)">
            <div class="ret-k">D30 returned</div>
            <div class="ret-v">@Pct(Model.Summary.Day30)</div>
            <div class="ret-n">over @Model.Summary.CohortsUsedDay30.ToString("N0") cohorts</div>
        </div>
    </div>
</section>

@if (Model.Cohorts.Count > 0)
{
    @* New-users-per-day and the D0→D30 decay curve, both derived from the cohort rows already
       loaded for the table below — no extra queries. *@
    var newUsersByDay = Model.Cohorts
        .GroupBy(c => c.InstallDay)
        .OrderBy(g => g.Key)
        .Select(g => new RSALinePoint(g.Key.ToString("MM-dd"), g.Sum(c => c.CohortSize)))
        .ToList();
    var newUsersStep = Math.Max(1, (int)Math.Ceiling(newUsersByDay.Count / 8.0));
    var retentionCurve = new List<RSALinePoint>
    {
        new("Day 0", 100),
        new("Day 1", Math.Round(Model.Summary.Day1 * 100, 1)),
        new("Day 7", Math.Round(Model.Summary.Day7 * 100, 1)),
        new("Day 30", Math.Round(Model.Summary.Day30 * 100, 1)),
    };

    <div class="charts-row">
        <section class="card chart-card">
            <h3>New users / day</h3>
            @await Html.PartialAsync("_LineChart", new RSALineChartVM(
                newUsersByDay, ValueNoun: "users", LabelStep: newUsersStep,
                AriaLabel: $"New users per install day over the last {Model.WindowDays} days"))
        </section>
        <section class="card chart-card">
            <h3>Retention curve</h3>
            @await Html.PartialAsync("_LineChart", new RSALineChartVM(
                retentionCurve, ValueNoun: "%",
                AriaLabel: "Weighted retention from install through day 30"))
        </section>
    </div>
    <p class="legend">New users counts each install-day cohort's size; the retention curve plots the weighted D1/D7/D30 share still active, anchored at 100% on install day.</p>
}

<section class="card">
    <h2>Cohorts</h2>
    @if (Model.Cohorts.Count == 0)
    {
        <empty-state>No cohorts in the window. The cohort worker writes one row per (platform, install_day) on every tick.</empty-state>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th scope="col" sort="date" tip="The install-day cohort — every user whose first-ever event fell on this date.">Install day</th>
                    <th scope="col" sort="text" tip="The platform the cohort's users are on (iOS or Android).">Platform</th>
                    <th scope="col" sort="num" tip="Cohort size: distinct new users who installed on this day.">Cohort</th>
                    <th scope="col" sort="num" tip="Fraction of the cohort that returned with an event 1 day after install (retained count in parentheses).">D1</th>
                    <th scope="col" sort="num" tip="Fraction of the cohort that returned 7 days after install (retained count in parentheses).">D7</th>
                    <th scope="col" sort="num" tip="Fraction of the cohort that returned 30 days after install (retained count in parentheses).">D30</th>
                    <th scope="col" tip="Which anonymous-ID pepper key was active when the cohort was computed — cohorts across a key rotation aren't directly comparable.">Hash v.</th>
                    <th scope="col" sort="date" tip="When the cohort worker last recomputed this row.">Computed</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var c in Model.Cohorts)
            {
                string Rate(long r) => c.CohortSize <= 0 ? "—" : ((double)r / c.CohortSize * 100).ToString("F1") + "%";
                string Cell(long r) => c.CohortSize <= 0 ? "" : Bucket((double)r / c.CohortSize);
                double SortRate(long r) => c.CohortSize <= 0 ? -1 : (double)r / c.CohortSize;
                <tr>
                    <td class="mono" data-sort-value="@c.InstallDay.ToString("yyyy-MM-dd")">@c.InstallDay.ToString("yyyy-MM-dd")</td>
                    <td class="mono">@c.Platform</td>
                    <td data-sort-value="@c.CohortSize">@c.CohortSize.ToString("N0")</td>
                    <td class="ret-cell @Cell(c.Day1Retained)" data-sort-value="@SortRate(c.Day1Retained)">@Rate(c.Day1Retained) <span class="muted">(@c.Day1Retained.ToString("N0"))</span></td>
                    <td class="ret-cell @Cell(c.Day7Retained)" data-sort-value="@SortRate(c.Day7Retained)">@Rate(c.Day7Retained) <span class="muted">(@c.Day7Retained.ToString("N0"))</span></td>
                    <td class="ret-cell @Cell(c.Day30Retained)" data-sort-value="@SortRate(c.Day30Retained)">@Rate(c.Day30Retained) <span class="muted">(@c.Day30Retained.ToString("N0"))</span></td>
                    <td class="mono">@c.HashVersion</td>
                    <td class="mono" data-sort-value="@c.ComputedAt.UtcDateTime.ToString("o")">@c.ComputedAt.AsLocalTime()</td>
                </tr>
            }
            </tbody>
        </table>
    }
</section>
