@page
@model RSAReportsModel
@using ReportService.Admin.ViewModels
@{
    ViewData["Title"] = "Reports";
    var filter = Model.Filter;
    var vm = Model.Listing;
    var rowDeleteUrl = $"/Reports{filter.ToQueryString(1)}&handler=DeleteOne";
}
@await Html.PartialAsync("_PageHeader", new RSAPageHeaderVM("Reports", "Filter, search, and paginate every stored submission."))

@await Html.PartialAsync("_ReportsFilter", new RSAReportsFilterPanelVM("/Reports", filter, Model.AvailablePlatforms))

@section Scripts {
    <script src="~/js/auto-submit.js" asp-append-version="true"></script>
}

<p class="muted">
    @vm.TotalMatched matches · page @vm.PageNumber of @vm.TotalPages
    · source: <span class="mono">@(vm.UsedIndex ? "sqlite index" : "filesystem scan")</span>
</p>

@await Html.PartialAsync("_DeleteFilteredBar", new RSADeleteBarVM(
    $"/Reports{filter.ToQueryString(1)}&handler=DeleteMatching", vm.TotalMatched, "report"))

@if (vm.Items.Count == 0)
{
    <empty-state>No reports match the current filter.</empty-state>
}
else
{
    <table>
        <thead>
            <tr>
                <th scope="col" tip="When the report was submitted, shown in your local time">Submitted</th>
                <th scope="col" tip="Originating platform (android or ios)">Platform</th>
                <th scope="col" tip="Submission channel the report arrived through">Channel</th>
                <th scope="col" tip="Report file name; links to the full report detail">File</th>
                <th scope="col" tip="On-disk size of the report payload">Size</th>
                <th scope="col" tip="Size of the attached log/file, or empty if none">Attachment</th>
                <th scope="col" aria-label="Delete"></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var r in vm.Items)
        {
            <tr>
                <td class="mono">@r.SubmittedAt.AsLocalTime()</td>
                <td class="mono">@r.Platform</td>
                <td>@await Html.PartialAsync("_ChannelBadge", r)</td>
                <td class="mono"><a asp-page="/Report" asp-route-platform="@r.Platform" asp-route-fileName="@r.FileName">@r.FileName</a></td>
                <td>@RSAByteFormatter.Format(r.SizeBytes)</td>
                <td>@RSAByteFormatter.Format(r.AttachmentSizeBytes)</td>
                <td>@await Html.PartialAsync("_RowDelete", new RSARowDeleteVM(rowDeleteUrl, r.Platform, r.FileName))</td>
            </tr>
        }
        </tbody>
    </table>
}

@await Html.PartialAsync("_Pager", new RSAPagerVM(
    vm.PageNumber > 1 ? filter.ToQueryString(vm.PageNumber - 1) : null,
    vm.PageNumber < vm.TotalPages ? filter.ToQueryString(vm.PageNumber + 1) : null,
    $"page {vm.PageNumber} / {vm.TotalPages}"))
