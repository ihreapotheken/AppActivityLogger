@page
@model RSAAnalyticsFunnelsModel
@using ReportService.Admin.ViewModels
@{
    ViewData["Title"] = "Analytics funnels";
    var first = Model.Stats.Count > 0 ? Model.Stats[0].SessionsReached : 0;
    string Conversion(long reached) => first <= 0 ? "—" : ((double)reached / first * 100).ToString("F1") + "%";
}
@await Html.PartialAsync("_PageHeader", new RSAPageHeaderVM("Analytics funnels", $"How many sessions reach each step of a flow, and where they drop off. Window: last {Model.Window} days."))

<hint-box docs-href="/Documentation#06-analytics--reading-funnels">
    <p>
        A funnel shows how many sessions get through an ordered flow and where they drop off. Each step
        counts the distinct sessions that completed it <em>and</em> every step before it, in order — so the
        numbers can only fall as you go down. <strong>Conversion</strong> compares each step back to step 0;
        <strong>vs previous</strong> is the step-to-step rate and is the clearest signal of <em>where</em>
        people leave. Use the platform filter to compare Android against iOS — a large gap usually points to
        a platform-specific problem.
    </p>
</hint-box>

<form method="get" class="filters" aria-label="Funnel filters">
    <label>Funnel
        <select name="funnel">
            @foreach (var d in Model.Definitions)
            {
                <option value="@d.FunnelKey" selected="@(Model.Selected is not null && string.Equals(d.FunnelKey, Model.Selected.FunnelKey, StringComparison.Ordinal))">@d.DisplayName</option>
            }
        </select>
    </label>
    <label>Platform
        <select name="platform">
            <option value="">all</option>
            @foreach (var p in Model.AvailablePlatforms)
            {
                <option value="@p" selected="@(string.Equals(Model.Platform, p, StringComparison.OrdinalIgnoreCase))">@p</option>
            }
        </select>
    </label>
    <button type="submit" class="primary">Apply</button>
</form>

@if (Model.Definitions.Count == 0)
{
    <empty-state>No funnels defined. The funnel worker seeds default definitions on first start; if it hasn't run yet, restart the service or wait one funnel interval.</empty-state>
}
else if (Model.Selected is null)
{
    <empty-state>Funnel not found.</empty-state>
}
else
{
    <section class="card">
        <h2>@Model.Selected.DisplayName <span class="mono muted">(@Model.Selected.FunnelKey)</span></h2>
        <table class="funnel-table">
            <thead>
                <tr>
                    <th scope="col" sort="num" tip="Step position in the funnel sequence (0 = entry). Sort to restore sequence order.">#</th>
                    <th scope="col" sort="text" tip="Human-readable name of this funnel step.">Step</th>
                    <th scope="col" tip="The event name and type that advances a session to this step ('any' = type not constrained).">Event</th>
                    <th scope="col" sort="num" tip="Distinct sessions that completed this step and every step before it, within the window.">Sessions</th>
                    <th scope="col" tip="Sessions reaching this step as a share of step 0, drawn as a bar.">Funnel (vs step 0)</th>
                    <th scope="col" sort="num" tip="Conversion from step 0: this step's sessions ÷ step 0's sessions.">Conversion</th>
                    <th scope="col" sort="num" tip="Step-over-step conversion: this step's sessions ÷ the previous step's — shows where users drop off.">vs previous</th>
                </tr>
            </thead>
            <tbody>
            @for (var i = 0; i < Model.Stats.Count; i++)
            {
                var s = Model.Stats[i];
                var def = Model.Selected.Steps[i];
                var conv = first <= 0 ? 0 : (double)s.SessionsReached / first * 100;
                var prev = i > 0 ? Model.Stats[i - 1].SessionsReached : s.SessionsReached;
                var stepOver = prev <= 0 ? "—" : ((double)s.SessionsReached / prev * 100).ToString("F1") + "%";
                var stepOverVal = prev <= 0 ? -1 : (double)s.SessionsReached / prev;
                var dropped = i > 0 && prev > s.SessionsReached;
                <tr>
                    <td data-sort-value="@i">@i</td>
                    <td>@def.Name</td>
                    <td class="mono">@def.EventName <span class="muted">/ @(def.EventType ?? "any")</span></td>
                    <td data-sort-value="@s.SessionsReached">@s.SessionsReached.ToString("N0")</td>
                    <td class="funnel-bar-cell">
                        @* SVG rect width is an attribute, not an inline style — CSP-safe. *@
                        <svg class="funnel-bar" viewBox="0 0 100 12" preserveAspectRatio="none" role="img" aria-label="@Conversion(s.SessionsReached) of step 0">
                            <rect class="funnel-bar-track" x="0" y="0" width="100" height="12"></rect>
                            <rect class="funnel-bar-fill" x="0" y="0" width="@conv.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" height="12"></rect>
                        </svg>
                    </td>
                    <td data-sort-value="@conv">@Conversion(s.SessionsReached)</td>
                    <td class="@(dropped ? "funnel-drop" : "")" data-sort-value="@stepOverVal">@stepOver</td>
                </tr>
            }
            </tbody>
        </table>
    </section>
}
