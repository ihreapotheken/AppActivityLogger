@page
@model RSAAnalyticsSessionsModel
@using ReportService.Admin.ViewModels
@{
    ViewData["Title"] = "Analytics sessions";
}
@await Html.PartialAsync("_PageHeader", new RSAPageHeaderVM("Analytics sessions", "Most recently active sessions. Click into a session for the full event timeline."))

<p>
    One row per logical user session as identified by the SDK's <code>sessionId</code> field.
    Event count and screen count are accumulated by the aggregation worker and are idempotent —
    retried batches don't inflate the totals because each event is only counted the first time it's aggregated.
    Sessions are sorted by last-seen timestamp, so the most recently active users appear first.
    Click a session ID to replay the full event sequence with timestamps, properties, and durations.
</p>

<form method="get" class="filters" aria-label="Session filters">
    <label>Platform
        <select name="platform">
            <option value="">all</option>
            @foreach (var p in Model.AvailablePlatforms)
            {
                <option value="@p" selected="@(string.Equals(Model.Platform, p, StringComparison.OrdinalIgnoreCase))">@p</option>
            }
        </select>
    </label>
    <button type="submit" class="primary">Apply</button>
</form>

<span id="list" class="list-anchor"></span>
@if (Model.Rows.Count == 0)
{
    <empty-state>No sessions recorded yet. The aggregation worker upserts sessions as events flow in.</empty-state>
}
else
{
    <table>
        <thead>
            <tr>
                <th scope="col" tip="Timestamp of the most recent event in this session (local time)">Last seen</th>
                <th scope="col" tip="Timestamp of the first event in this session (local time)">Started</th>
                <th scope="col" tip="Client platform reported by the SDK (e.g. android, ios)">Platform</th>
                <th scope="col" tip="Total events aggregated into this session (deduplicated, retry-safe)">Events</th>
                <th scope="col" tip="Distinct screens viewed during this session">Screens</th>
                <th scope="col" tip="SDK sessionId; click to replay the full event timeline">Session</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var s in Model.Rows)
        {
            <tr>
                <td class="mono">@s.LastSeenAt.AsLocalTime()</td>
                <td class="mono">@s.StartedAt.AsLocalTime()</td>
                <td class="mono">@s.Platform</td>
                <td>@s.EventCount.ToString("N0")</td>
                <td>@s.ScreenCount.ToString("N0")</td>
                <td class="mono"><a asp-page="/AnalyticsSession" asp-route-app="@s.AppId" asp-route-env="@s.Environment" asp-route-client="@s.ClientId" asp-route-platform="@s.Platform" asp-route-id="@s.SessionId">@s.SessionId</a></td>
            </tr>
        }
        </tbody>
    </table>

    @await Html.PartialAsync("_Pager", new RSAPagerVM(
        Model.PageNumber > 1 ? Model.BuildPageHref(Model.PageNumber - 1) : null,
        Model.Rows.Count == 50 ? Model.BuildPageHref(Model.PageNumber + 1) : null,
        $"page {Math.Max(1, Model.PageNumber)}"))
}
