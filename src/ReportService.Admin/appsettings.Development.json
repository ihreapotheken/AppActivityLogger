{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "ReportService": {
    "Storage": "SqliteIndex"
  },
  "Analytics": {
    "AggregationIntervalSeconds": 5,
    "AggregationBatchSize": 40000,
    "CohortIntervalSeconds": 15,
    "FunnelIntervalSeconds": 15,
    "RawEventRetentionDays": 365
  }
}
